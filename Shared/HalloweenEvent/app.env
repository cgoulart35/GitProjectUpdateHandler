# WEBAPP PROPERTIES
VERSION=1.0
TZ=America/New_York
LOG_LEVEL=INFO
WEBAPP_PORT=5004
SECRET_KEY=

# COMMUNICATION PROPERTIES
API_HOST=

# CREDENTIAL PROPERTIES
FIREBASE_CONFIG_JSON=

# AUTH PROPERTIES (secret -- required; must match api.env API_KEY)
API_KEY=

# CAPTCHA PROPERTIES (Cloudflare Turnstile; leave blank to disable CAPTCHA for local/QA dev)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# QA ONLY -- leave blank/unset in production.
# EVENT_ROOT=
